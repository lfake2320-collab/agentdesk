HOST=127.0.0.1
PORT=7676
# Owner password generated by `devspace init` in ~/.devspace/auth.json. Set this
# only for non-interactive or fully env-driven deployments.
# DEVSPACE_OAUTH_OWNER_TOKEN=change-me-to-a-long-random-secret
# Optional OAuth tuning.
# DEVSPACE_OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
# DEVSPACE_OAUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
# DEVSPACE_OAUTH_SCOPES=devspace
# DEVSPACE_OAUTH_ALLOWED_REDIRECT_HOSTS=chatgpt.com,localhost,127.0.0.1
DEVSPACE_ALLOWED_ROOTS=/home/waishnav/personal,/home/waishnav/work
# For temporary tunnels, prefer setting this per run. DevSpace derives the
# inbound Host allowlist from this URL.
# DEVSPACE_PUBLIC_BASE_URL=https://your-public-host.example.com
# Advanced escape hatch. `*` disables Host header allowlist protection.
# DEVSPACE_ALLOWED_HOSTS=localhost,127.0.0.1,your-public-host.example.com
DEVSPACE_TOOL_MODE=full
# safe | dev | power | owner. Defaults to dev.
# Higher profiles tell hosts to use deeper local diagnostics while still requiring confirmation for destructive actions.
DEVSPACE_PERMISSION_PROFILE=power
# off | changes | full. Defaults to full.
# changes creates one aggregate review widget via show_changes instead of per-tool iframes.
DEVSPACE_WIDGETS=changes
DEVSPACE_LOG_LEVEL=info
DEVSPACE_LOG_FORMAT=json
DEVSPACE_LOG_REQUESTS=1
DEVSPACE_LOG_ASSETS=0
DEVSPACE_LOG_TOOL_CALLS=1
DEVSPACE_LOG_SHELL_COMMANDS=0
# DEVSPACE_TRUST_PROXY=1
# DEVSPACE_STATE_DIR=/home/waishnav/.local/share/devspace
# DEVSPACE_WORKTREE_ROOT=/home/waishnav/.devspace/worktrees
# DEVSPACE_AUTO_LOAD_AGENTS_MD=1
# Skills are enabled by default. Set DEVSPACE_SKILLS=0 to hide them.
# DEVSPACE_SKILLS=0
# DEVSPACE_AGENT_DIR=/home/waishnav/.codex
# DEVSPACE_SKILL_PATHS=/home/waishnav/.codex/skills,/home/waishnav/.claude/skills
# Plugin manifests are enabled by default. They are metadata/capability hints;
# tools still need to be exposed by a real MCP host or extension adapter.
# DEVSPACE_PLUGINS=1
# DEVSPACE_PLUGIN_PATHS=/home/waishnav/.devspace/plugins,/home/waishnav/company/devspace-plugins
# Read-only local system diagnostic tools are enabled by default only for power/owner profiles.
# DEVSPACE_SYSTEM_TOOLS=1
# Destructive process termination is disabled by default and only exposed in owner profile.
# DEVSPACE_PROCESS_CONTROL=0
# Browser control tools are disabled by default. Enable only for explicit, user-authorized web automation.
# DEVSPACE_BROWSER_TOOLS=0
# Browser profile modes: isolated = separate AgentDesk profile; live = Edge user profile with existing login state.
# DEVSPACE_BROWSER_MODE=isolated
# Edge is preferred by default. Override only when needed.
# DEVSPACE_BROWSER_EXECUTABLE=C:\\Program Files\\Microsoft\\Edge\\Application\\msedge.exe
# DEVSPACE_BROWSER_DEBUG_PORT=9222
# Live mode options. Profile names are usually Default, Profile 1, Profile 2, etc.
# DEVSPACE_BROWSER_USER_DATA_DIR=C:\\Users\\YOU\\AppData\\Local\\Microsoft\\Edge\\User Data
# DEVSPACE_BROWSER_PROFILE_DIRECTORY=Default
# Set to 1 to attach to an already-debuggable Edge instance instead of launching one.
# DEVSPACE_BROWSER_ATTACH_ONLY=0
